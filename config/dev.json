{
  "schema_version": "0.1",
  "kind": "aegis_config",
  "app": {
    "name": "aegis",
    "display_name": "Aegis",
    "mode": "dev",
    "default_profile": "coding_agent"
  },
  "runtime": {
    "max_steps": 40,
    "max_tool_calls": 120,
    "max_wall_time_ms": 1200000,
    "stop_on_tool_error": false,
    "stop_on_policy_denied": false,
    "retry": {
      "enabled": true,
      "max_retries": 2,
      "backoff_ms": 500
    }
  },
  "provider": {
    "active": "openrouter",
    "providers": {
      "openrouter": {
        "base_url": "https://openrouter.ai/api/v1",
        "chat_completions_path": "/chat/completions",
        "api_key_env": "OPENROUTER_API_KEY",
        "timeout_ms": 120000,
        "connect_timeout_ms": 10000,
        "headers": {
          "HTTP-Referer": {
            "type": "env",
            "env": "AEGIS_OPENROUTER_REFERER",
            "default": "http://localhost"
          },
          "X-OpenRouter-Title": {
            "type": "literal",
            "value": "Aegis-C"
          }
        }
      }
    }
  },
  "model": {
    "active_profile": "default",
    "profiles": {
      "default": {
        "model": "moonshotai/kimi-k2.6:free",
        "temperature": 0.15,
        "top_p": 0.9,
        "max_tokens": 6144,
        "stream": false,
        "provider_routing": {
          "allow_fallbacks": true,
          "require_parameters": true,
          "data_collection": "deny",
          "zdr": false,
          "order": [],
          "only": [],
          "ignore": []
        },
        "response_format": {
          "type": "json_schema",
          "json_schema": {
            "name": "aegis_agent_action",
            "strict": true,
            "schema": {
              "type": "object",
              "oneOf": [
                {
                  "type": "object",
                  "required": ["type", "message"],
                  "properties": {
                    "type": { "const": "final" },
                    "message": { "type": "string" }
                  },
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "required": ["type", "tool", "arguments"],
                  "properties": {
                    "type": { "const": "tool_call" },
                    "tool": { "type": "string" },
                    "arguments": { "type": "object" }
                  },
                  "additionalProperties": false
                }
              ]
            }
          }
        }
      }
    }
  },
  "agent": {
    "profile_directory": "profiles",
    "default_profile": "coding_agent",
    "profile_file_suffix": ".json",
    "action_protocol": "json_action_v1",
    "allowed_actions": ["final", "tool_call"],
    "force_json_action": true,
    "invalid_json_repair_attempts": 2,
    "resolution": {
      "tool_access": "intersection",
      "policy_authority": "config",
      "limit_strategy": "most_restrictive",
      "model_source": "config",
      "allowed_profile_model_overrides": ["temperature", "top_p", "max_tokens"]
    }
  },
  "context": {
    "include_system_prompt": true,
    "include_tool_schemas": true,
    "include_workspace_summary": true,
    "include_recent_observations": true,
    "include_recent_file_reads": true,
    "max_history_events": 30,
    "max_file_read_bytes": 131072,
    "max_tool_output_bytes": 131072,
    "summarize_old_history": true
  },
  "workspace": {
    "root": ".",
    "restrict_to_root": true,
    "deny_absolute_paths": true,
    "deny_parent_traversal": true,
    "follow_symlinks": false,
    "allow_hidden_files": true,
    "max_file_bytes": 2097152,
    "blocked_paths": [
      ".git/objects",
      ".env",
      ".ssh",
      "id_rsa",
      "id_ed25519",
      "secrets.json"
    ]
  },
  "tools": {
    "enabled": [
      "list_dir",
      "read_file",
      "write_file",
      "append_file"
    ],
    "disabled": [
      "search_file",
      "shell",
      "run_tests",
      "git_status",
      "git_diff",
      "git_log",
      "git_apply_patch",
      "http_get",
      "http_post",
      "ask_user",
      "send_message",
      "reminder",
      "read_log",
      "grep_log",
      "health_check",
      "mcp_tool"
    ],
    "defaults": {
      "require_policy_check": true,
      "require_trace": true,
      "max_result_bytes": 131072
    },
    "file": {
      "allow_read": true,
      "allow_write": true,
      "write_requires_approval": false
    },
    "http": {
      "enabled": false,
      "timeout_ms": 30000,
      "max_response_bytes": 1048576,
      "allowed_schemes": ["https"],
      "allow_private_networks": false
    },
    "shell": {
      "enabled": false,
      "requires_approval": true,
      "timeout_ms": 30000,
      "max_output_bytes": 131072,
      "working_directory": "workspace",
      "env_policy": "whitelist",
      "allowed_env": [
        "PATH",
        "HOME",
        "LANG",
        "LC_ALL",
        "CC",
        "CXX",
        "CFLAGS",
        "CXXFLAGS",
        "MAKEFLAGS"
      ],
      "allowed_commands": [
        "ls",
        "cat",
        "grep",
        "find",
        "make",
        "cmake",
        "ctest",
        "ninja",
        "git status",
        "git diff",
        "git log"
      ],
      "blocked_commands": [
        "sudo",
        "su",
        "rm -rf /",
        "dd",
        "mkfs",
        "mount",
        "umount",
        "chmod 777",
        "chown",
        "curl | sh",
        "wget | sh",
        "ssh",
        "scp",
        "iptables",
        "nft",
        "reboot",
        "shutdown"
      ]
    }
  },
  "policy": {
    "mode": "dev",
    "approval_mode": "on_risky_action",
    "default_decision": "deny_unknown",
    "decisions": {
      "list_dir": "allow",
      "read_file": "allow",
      "write_file": "allow",
      "append_file": "allow",
      "search_file": "deny",
      "shell": "deny",
      "run_tests": "deny",
      "git_status": "deny",
      "git_diff": "deny",
      "git_log": "deny",
      "git_apply_patch": "deny",
      "http_get": "deny",
      "http_post": "deny",
      "ask_user": "deny",
      "send_message": "deny",
      "reminder": "deny",
      "read_log": "deny",
      "grep_log": "deny",
      "health_check": "deny",
      "mcp_tool": "deny"
    },
    "risk_levels": {
      "list_dir": "low",
      "read_file": "low",
      "write_file": "medium",
      "append_file": "medium",
      "search_file": "low",
      "shell": "high",
      "run_tests": "medium",
      "git_status": "low",
      "git_diff": "low",
      "git_log": "low",
      "git_apply_patch": "medium",
      "http_get": "high",
      "http_post": "critical",
      "ask_user": "low",
      "send_message": "critical",
      "reminder": "medium",
      "read_log": "low",
      "grep_log": "low",
      "health_check": "medium",
      "mcp_tool": "high"
    }
  },
  "sandbox": {
    "enabled": true,
    "type": "soft_posix",
    "chdir_to_workspace": true,
    "network": { "enabled": false },
    "limits": {
      "cpu_time_seconds": 60,
      "memory_bytes": 1073741824,
      "file_size_bytes": 52428800,
      "process_count": 64
    },
    "hardening": {
      "seccomp": false,
      "landlock": false,
      "namespaces": false,
      "rlimit": true
    }
  },
  "state": {
    "enabled": true,
    "driver": "sqlite",
    "path": "state/aegis-dev.db",
    "auto_migrate": true,
    "store_messages": true,
    "store_tool_calls": true,
    "store_tool_results": true,
    "store_approvals": true
  },
  "trace": {
    "enabled": true,
    "driver": "jsonl",
    "directory": "traces/dev",
    "file_pattern": "{session_id}.jsonl",
    "flush_each_event": true,
    "include_llm_requests": true,
    "include_llm_responses": true,
    "include_tool_results": true,
    "redact_secrets": true
  },
  "logging": {
    "level": "debug",
    "stderr": true,
    "file": {
      "enabled": true,
      "path": "state/aegis-dev.log"
    }
  },
  "redaction": {
    "enabled": true,
    "patterns": [
      "OPENROUTER_API_KEY",
      "AEGIS_API_KEY",
      "OPENAI_API_KEY",
      "ANTHROPIC_API_KEY",
      "GITHUB_TOKEN",
      "PASSWORD",
      "SECRET",
      "TOKEN"
    ]
  },
  "adapters": {
    "cli": {
      "enabled": true,
      "default_user_id": "local",
      "default_session_prefix": "dev"
    },
    "http": {
      "enabled": false,
      "host": "127.0.0.1",
      "port": 8787
    },
    "telegram": {
      "enabled": false,
      "bot_token_env": "AEGIS_TELEGRAM_BOT_TOKEN"
    },
    "discord": {
      "enabled": false,
      "bot_token_env": "AEGIS_DISCORD_BOT_TOKEN"
    }
  },
  "mcp": {
    "enabled": false,
    "clients": [],
    "default_policy": "deny"
  },
  "eval": {
    "enabled": true,
    "suite_directory": "evals/suites",
    "workspace_directory": "evals/workspaces",
    "default_success_command": "make test",
    "max_eval_steps": 40
  }
}
