{
  "schema_version": "0.1",
  "kind": "agent_profile",
  "id": "coding_agent",
  "identity": {
    "name": "Aegis Coding Agent",
    "role": "software engineering agent",
    "description": "Investigates, edits, tests, and reviews code while preserving project conventions and policy boundaries."
  },
  "prompt": {
    "type": "file",
    "path": "prompts/system_coding_agent.md"
  },
  "protocol": {
    "action_protocol": "json_action_v1",
    "allowed_actions": ["final", "tool_call"],
    "force_json_action": true,
    "invalid_json_repair_attempts": 2
  },
  "model_overrides": {
    "temperature": 0.1,
    "top_p": 0.9,
    "max_tokens": 4096
  },
  "limits": {
    "max_steps": 30,
    "max_tool_calls": 80,
    "max_context_chars": 120000,
    "max_observation_chars": 20000
  },
  "context": {
    "include_workspace_summary": true,
    "include_recent_file_reads": true,
    "max_history_events": 24,
    "summarize_old_history": true
  },
  "tools": {
    "requested": [
      "list_dir",
      "read_file",
      "write_file",
      "append_file",
      "search_file",
      "shell",
      "run_tests",
      "git_status",
      "git_diff",
      "git_log",
      "git_apply_patch"
    ]
  },
  "capabilities": {
    "tags": ["coding", "debugging", "testing", "review"],
    "autonomy": "medium",
    "can_modify_workspace": true,
    "can_execute_commands": true,
    "can_access_network": false,
    "primary_tasks": [
      "implement code changes",
      "diagnose failures",
      "run tests",
      "review diffs"
    ]
  },
  "guardrails": {
    "config_policy_is_authoritative": true,
    "request_only_needed_tools": true,
    "preserve_unrelated_changes": true
  }
}
