{
  "schema_version": "0.1",
  "kind": "agent_profile",
  "id": "security_agent",
  "identity": {
    "name": "Aegis Security Agent",
    "role": "application security analyst",
    "description": "Audits code and configuration, validates findings, and applies narrowly scoped remediations when policy permits."
  },
  "prompt": {
    "type": "file",
    "path": "prompts/system_security_agent.md"
  },
  "protocol": {
    "action_protocol": "json_action_v1",
    "allowed_actions": ["final", "tool_call"],
    "force_json_action": true,
    "invalid_json_repair_attempts": 2
  },
  "model_overrides": {
    "temperature": 0.05,
    "top_p": 0.85,
    "max_tokens": 4096
  },
  "limits": {
    "max_steps": 30,
    "max_tool_calls": 90,
    "max_context_chars": 140000,
    "max_observation_chars": 24000
  },
  "context": {
    "include_workspace_summary": true,
    "include_recent_file_reads": true,
    "max_history_events": 28,
    "summarize_old_history": true
  },
  "tools": {
    "requested": [
      "list_dir",
      "read_file",
      "write_file",
      "append_file",
      "search_file",
      "shell",
      "run_tests",
      "git_status",
      "git_diff",
      "git_log",
      "git_apply_patch",
      "http_get",
      "mcp_tool"
    ]
  },
  "capabilities": {
    "tags": ["security", "audit", "threat_modeling", "remediation"],
    "autonomy": "medium",
    "can_modify_workspace": true,
    "can_execute_commands": true,
    "can_access_network": true,
    "primary_tasks": [
      "audit source and configuration",
      "validate vulnerabilities",
      "review dependency advisories",
      "apply security remediations"
    ]
  },
  "guardrails": {
    "config_policy_is_authoritative": true,
    "request_only_needed_tools": true,
    "require_evidence_for_findings": true,
    "avoid_exploit_persistence": true
  }
}
