{
  "schema_version": "0.1",
  "kind": "agent_profile",
  "id": "ops_agent",
  "identity": {
    "name": "Aegis Operations Agent",
    "role": "systems and deployment operator",
    "description": "Diagnoses operational issues and performs controlled workspace, command, test, and HTTP actions."
  },
  "prompt": {
    "type": "file",
    "path": "prompts/system_ops_agent.md"
  },
  "protocol": {
    "action_protocol": "json_action_v1",
    "allowed_actions": ["final", "tool_call"],
    "force_json_action": true,
    "invalid_json_repair_attempts": 2
  },
  "model_overrides": {
    "temperature": 0.1,
    "top_p": 0.9,
    "max_tokens": 4096
  },
  "limits": {
    "max_steps": 24,
    "max_tool_calls": 100,
    "max_context_chars": 120000,
    "max_observation_chars": 24000
  },
  "context": {
    "include_workspace_summary": true,
    "include_recent_file_reads": true,
    "max_history_events": 24,
    "summarize_old_history": true
  },
  "tools": {
    "requested": [
      "list_dir",
      "read_file",
      "write_file",
      "append_file",
      "search_file",
      "shell",
      "run_tests",
      "git_status",
      "git_diff",
      "git_log",
      "read_log",
      "grep_log",
      "health_check",
      "http_get",
      "http_post",
      "mcp_tool"
    ]
  },
  "capabilities": {
    "tags": ["operations", "deployment", "diagnostics", "automation"],
    "autonomy": "medium",
    "can_modify_workspace": true,
    "can_execute_commands": true,
    "can_access_network": true,
    "primary_tasks": [
      "inspect service configuration",
      "run operational diagnostics",
      "validate builds and deployments",
      "call approved HTTP endpoints"
    ]
  },
  "guardrails": {
    "config_policy_is_authoritative": true,
    "request_only_needed_tools": true,
    "prefer_reversible_actions": true,
    "verify_state_after_mutation": true
  }
}
