{
  "schema_version": "0.1",
  "kind": "agent_profile",
  "id": "assistant_agent",
  "identity": {
    "name": "Aegis Assistant Agent",
    "role": "general research and workspace assistant",
    "description": "Answers general questions using local read access and approved web retrieval without modifying the workspace."
  },
  "prompt": {
    "type": "file",
    "path": "prompts/system_assistant_agent.md"
  },
  "protocol": {
    "action_protocol": "json_action_v1",
    "allowed_actions": ["final", "tool_call"],
    "force_json_action": true,
    "invalid_json_repair_attempts": 2
  },
  "model_overrides": {
    "temperature": 0.2,
    "top_p": 0.9,
    "max_tokens": 2048
  },
  "limits": {
    "max_steps": 12,
    "max_tool_calls": 30,
    "max_context_chars": 80000,
    "max_observation_chars": 16000
  },
  "context": {
    "include_system_prompt": true,
    "include_tool_schemas": true,
    "include_workspace_summary": true,
    "include_recent_observations": true,
    "include_recent_file_reads": true,
    "max_history_events": 16,
    "summarize_old_history": true
  },
  "tools": {
    "requested": [
      "list_dir",
      "read_file",
      "search_file",
      "http_get",
      "ask_user",
      "send_message",
      "reminder"
    ]
  },
  "capabilities": {
    "tags": ["assistant", "research", "read_only"],
    "autonomy": "low",
    "can_modify_workspace": false,
    "can_execute_commands": false,
    "can_access_network": true,
    "primary_tasks": [
      "answer general questions",
      "summarize local documents",
      "retrieve approved public information"
    ]
  },
  "guardrails": {
    "config_policy_is_authoritative": true,
    "request_only_needed_tools": true,
    "avoid_side_effects": true,
    "cite_external_information": true
  }
}
